/* pages/index/index.wxss */

.app-container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  position: relative;
  background-color: var(--bg-app);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* Header */
.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: var(--bg-card);
  border-bottom: 2rpx solid var(--border-color);
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  display: flex;
  align-items: center;
}

.logo-icon {
  font-size: 38rpx;
  color: var(--accent);
  margin-right: 12rpx;
  font-weight: bold;
}

.logo-text-group {
  display: flex;
  flex-direction: column;
}

.logo-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.2;
}

.logo-sub {
  font-size: 20rpx;
  color: var(--text-secondary);
}

.header-actions {
  display: flex;
  align-items: center;
}

.icon-btn {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: var(--bg-card-hover);
  transition: var(--transition);
}

.emoji-icon {
  font-size: 32rpx;
}

/* Workspace */
.app-main {
  flex: 1;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* Input Card */
.input-card {
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.input-header {
  display: flex;
  flex-direction: column;
  margin-bottom: 20rpx;
}

.input-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-tip {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

.textarea-wrapper {
  background-color: var(--bg-app);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.words-textarea {
  width: 100%;
  height: 160rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
}

.textarea-placeholder {
  color: var(--text-muted);
}

.input-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.action-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.secondary-btn-sm {
  background-color: var(--bg-card-hover);
  color: var(--text-secondary);
  border-radius: var(--radius-sm);
  font-size: 24rpx;
  padding: 12rpx 20rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  transition: all 0.2s ease;
}

.secondary-btn-sm:active {
  background-color: var(--border-color);
  transform: scale(0.96);
}

.btn-icon {
  font-size: 26rpx;
}

.text-btn-sm {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 10rpx;
}

.primary-btn-submit {
  background-color: var(--accent);
  color: #ffffff;
  border-radius: var(--radius-sm);
  font-size: 26rpx;
  font-weight: 600;
  padding: 16rpx 36rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.primary-btn-submit.disabled {
  opacity: 0.6;
  pointer-events: none;
}

.primary-btn-submit:active {
  background-color: var(--accent-hover);
  transform: scale(0.96);
}

.spinner-small {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 50%;
  border-top-color: #fff;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 80rpx 40rpx;
  background-color: var(--bg-card);
  border: 2rpx dashed var(--border-color);
  border-radius: var(--radius-lg);
  margin-top: 20rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}

/* Loading Card */
.loading-card {
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-shadow: var(--shadow-sm);
}

.loading-skeleton-title {
  height: 36rpx;
  background-color: var(--bg-card-hover);
  border-radius: 8rpx;
  width: 40%;
  margin-bottom: 12rpx;
}

.loading-skeleton-text {
  height: 28rpx;
  background-color: var(--bg-card-hover);
  border-radius: 8rpx;
  width: 100%;
}

.loading-skeleton-text.half-width {
  width: 60%;
}

.skeleton-blink {
  animation: skeleton-pulse 1.2s infinite ease-in-out;
}

@keyframes skeleton-pulse {
  0% { opacity: 0.6; }
  50% { opacity: 0.3; }
  100% { opacity: 0.6; }
}

.loading-tip-container {
  margin-top: 40rpx;
  background-color: var(--accent-subtle);
  border-left: 6rpx solid var(--accent);
  padding: 20rpx 24rpx;
  border-radius: 0 var(--radius-md) var(--radius-md) 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.loading-tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--accent);
}

.loading-tip-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

/* Output Panel */
.output-panel {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.story-card {
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
}

.story-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 2rpx solid var(--border-color);
  padding-bottom: 20rpx;
  margin-bottom: 24rpx;
}

.story-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.speak-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: var(--accent-subtle);
  color: var(--accent);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.speak-btn.speaking {
  background-color: var(--success);
  color: #ffffff;
}

.speak-icon {
  font-size: 26rpx;
}

.story-body {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.story-content {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.7;
}

/* Make rich text strong tags look bold with accent color */
.story-content strong {
  font-weight: 700;
  color: var(--accent);
  background-color: var(--accent-glow);
  padding: 0 6rpx;
  border-radius: 6rpx;
}

.story-translation {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  border-top: 2rpx dashed var(--border-color);
  padding-top: 20rpx;
}

/* Vocab Section */
.vocab-section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-top: 10rpx;
}

.vocab-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.vocab-card {
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 24rpx;
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.vocab-card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.word-group {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
  flex-wrap: wrap;
}

.vocab-word {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.vocab-ipa {
  font-size: 24rpx;
  color: var(--text-muted);
}

.word-speak-btn {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background-color: var(--bg-card-hover);
  display: flex;
  align-items: center;
  justify-content: center;
}

.word-speak-icon {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.vocab-def-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vocab-pos {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--accent);
  background-color: var(--accent-subtle);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.vocab-definition {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.vocab-example-box {
  background-color: var(--bg-app);
  padding: 16rpx 20rpx;
  border-radius: var(--radius-sm);
  border-left: 4rpx solid var(--border-color);
  font-size: 24rpx;
  line-height: 1.5;
}

.example-label {
  color: var(--text-secondary);
  font-weight: 600;
}

.example-text {
  color: var(--text-primary);
  font-style: italic;
}

/* History Sidebar Drawer */
.sidebar-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background-color: rgba(15, 23, 42, 0.4);
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: all 0.28s ease;
}

.sidebar-backdrop.active {
  opacity: 1;
  visibility: visible;
}

.history-sidebar {
  position: fixed;
  top: 0;
  right: 0;
  width: 540rpx;
  height: 100vh;
  background-color: var(--bg-card);
  z-index: 201;
  box-shadow: -10rpx 0 30rpx rgba(0, 0, 0, 0.05);
  transform: translateX(100%);
  transition: all 0.28s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  flex-direction: column;
}

.history-sidebar.active {
  transform: translateX(0);
}

.sidebar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 2rpx solid var(--border-color);
}

.sidebar-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.clear-history-btn {
  font-size: 24rpx;
  color: var(--text-muted);
}

.sidebar-scroll {
  flex: 1;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid var(--border-color);
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-item:active {
  background-color: var(--bg-card-hover);
}

.history-words {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-time {
  font-size: 20rpx;
  color: var(--text-muted);
}

.history-empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 40rpx;
  font-size: 26rpx;
  color: var(--text-muted);
}

/* Crop Editor Styling */
.crop-editor-backdrop {
  position: fixed;
  left: 0;
  width: 100vw;
  background-color: rgba(15, 23, 42, 0.7);
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.crop-editor-card {
  background-color: var(--bg-card);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  width: 90%;
  max-width: 620rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  box-shadow: var(--shadow-lg);
}

.crop-editor-header {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.crop-editor-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.crop-editor-tip {
  font-size: 22rpx;
  color: var(--text-muted);
}

.crop-editor-body {
  background-color: #000;
  border-radius: var(--radius-md);
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 40vh;
  box-sizing: border-box;
}

.crop-image-container {
  overflow: hidden;
  box-sizing: border-box;
}

.crop-source-img {
  max-width: 100%;
  max-height: 50vh;
}

.crop-highlight-canvas {
  touch-action: none;
}

.crop-editor-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.crop-footer-right {
  display: flex;
  gap: 16rpx;
}
