/* app.wxss */
page {
  --bg-app: #f8fafc;        /* Slate 50 */
  --bg-card: #ffffff;
  --bg-card-hover: #f1f5f9;  /* Slate 100 */
  --bg-modal: #ffffff;
  --border-color: #e2e8f0;   /* Slate 200 */
  --border-hover: #cbd5e1;   /* Slate 300 */
  
  --text-primary: #0f172a;   /* Slate 900 */
  --text-secondary: #475569; /* Slate 600 */
  --text-muted: #94a3b8;     /* Slate 400 */
  
  --accent: #4f46e5;         /* Indigo 600 */
  --accent-hover: #4338ca;   /* Indigo 700 */
  --accent-glow: rgba(79, 70, 229, 0.08);
  --accent-subtle: rgba(79, 70, 229, 0.05);
  
  --success: #10b981;
  --danger: #ef4444;
  
  --radius-sm: 10rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  
  --shadow-sm: 0 2rpx 6rpx rgba(0, 0, 0, 0.05);
  --shadow-md: 0 8rpx 12rpx rgba(0, 0, 0, 0.05);
  --shadow-lg: 0 20rpx 50rpx rgba(0, 0, 0, 0.05);

  background-color: var(--bg-app);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
  font-size: 30rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, scroll-view, textarea, button, input {
  box-sizing: border-box;
}

/* Global utility classes for buttons matching web styling */
.primary-btn {
  background-color: var(--accent);
  color: #ffffff;
  border-radius: var(--radius-md);
  font-weight: 500;
  font-size: 28rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
  transition: all 0.2s ease;
}

.primary-btn:active {
  background-color: var(--accent-hover);
  transform: scale(0.98);
}

.secondary-btn {
  background-color: var(--bg-card);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-weight: 500;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 28rpx;
}

.secondary-btn:active {
  background-color: var(--bg-card-hover);
  transform: scale(0.98);
}

.text-btn {
  background: none;
  border: none;
  color: var(--text-secondary);
  font-size: 28rpx;
  padding: 10rpx;
}

.text-btn:active {
  color: var(--text-primary);
}
